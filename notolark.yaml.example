# Noto Lark — main configuration. Copy to notolark.yaml and fill in.
agent:
  # Pin the model your bot answers with (decoupled from your CLI default).
  model: "claude-opus-4-8[1m]"

lark:
  base_url: "https://open.larksuite.com"     # open.feishu.cn for Feishu
  tenant_url: "https://YOUR-TENANT.larksuite.com"
  # Chat where the bot posts engineering/ops alerts (optional):
  engineering_chat_id: ""
  # Shared calendar for add-to-calendar entries (optional; falls back
  # to the bot user's primary calendar):
  interview_calendar_id: ""
  # Expenses Base (optional — enables /expense + receipt logging):
  expenses_base_app_token: ""
  expenses_table_id: ""

paths:
  lark_cache_dir: "lark"

corpus:
  drive_root: ""            # folder token: the Drive tree to ingest
  wiki_spaces: []           # wiki space ids to ingest (empty = all visible)
  outputs_folder: ""        # folder token where the bot saves docs it creates

retrieval:
  semantic_floor_authoritative: 0.30
  semantic_floor_docs: 0.15

# Feature flags — ship OFF, flip deliberately (background jobs run the
# working tree, so new behaviors must be inert until you choose).
h2:
  email_summary_notes_enabled: false
  personal_preferences_enabled: false
  expenses_enabled: false
  screenshot_calendar_enabled: false

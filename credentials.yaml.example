# brain/credentials.yaml — TEMPLATE
#
# Copy this file to `brain/credentials.yaml` and fill in the real
# values. The real file is git-ignored so secrets never land in the
# repo. All values below are placeholders.
#
# Source of each value:
#   Lark Developer Console → your Noto app → various panels
#   (see docs/lark-app-setup.md for the click-path with screenshots)
#
# See docs/disaster-recovery.md if you're bootstrapping a new machine.

lark:
  # From "Credentials & Basic Info" panel
  app_id:     "cli_XXXXXXXXXXXXXX"
  app_secret: "XXXXXXXXXXXXXX"

  # From "Encryption Strategy" panel — click Regenerate for each,
  # then paste the full string here. The bot decrypts every inbound
  # webhook with encrypt_key + validates the verification_token.
  verification_token: "XXXXXXXXXXXXXX"
  encrypt_key:        "XXXXXXXXXXXXXX"

  # Optional overrides — these normally read from lolabot.yaml but
  # can be overridden here (e.g., if you use a different Bitable in
  # dev vs prod). Blank = fall back to lolabot.yaml.
  # bitable_app_token:      ""
  # bitable_table_pipeline: ""

dashboard:
  # Any random string. Used as the URL query key for the operator
  # dashboard (e.g. https://<host>/dashboard?key=<this>).
  # Generate with: openssl rand -hex 24
  key: "REPLACE-WITH-A-RANDOM-STRING"

# Optional: environment overrides also work if you'd rather set
# these as env vars in the launchd plists or shell profile.
# LARK_APP_ID, LARK_APP_SECRET, LARK_VERIFICATION_TOKEN,
# LARK_ENCRYPT_KEY are all supported by tools/config.py.

<?xml version="1.0" encoding="UTF-8"?>
<!-- Keep the Mac mini awake — it's an always-on agent server. System
     sleep was silently eating every overnight calendar job (mail miner,
     resync comb, jobs-daily) and explains the historic 03:42 cold-network
     failures. caffeinate -s -i prevents system+idle sleep while on AC.
     Display may still sleep (fine). KeepAlive revives it forever. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.noto.caffeinate</string>
  <key>ProgramArguments</key><array><string>/usr/bin/caffeinate</string><string>-s</string><string>-i</string></array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
</dict></plist>
